# ---------------------------------------------------------------------------
# Provider selection — choose ONE block and comment out the other.
# ---------------------------------------------------------------------------

# --- Option A: Groq (default) ---
GROQ_API_KEY=your_groq_api_key_here
MODEL_NAME=groq/llama-3.3-70b-versatile

# --- Option B: Gemini ---
# GENERIC_LLM_API_KEY=your_google_ai_studio_key_here
# MODEL_NAME=gemini/gemini-1.5-flash

# ---------------------------------------------------------------------------
# Required for all providers
# ---------------------------------------------------------------------------
SERPER_API_KEY=your_serper_api_key_here

MAX_SOURCES=3
MAX_STEPS=25
MAX_TOKENS=1000

# Optional — standing topics for the weekly scheduler (comma-separated)
# STANDING_TOPICS=AI developer tools market,Cloud infrastructure pricing
